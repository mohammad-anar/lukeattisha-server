model Review {
  id             String   @id @default(cuid())
  reviewNumber   String?  @unique
  userId         String
  storeServiceId String?
  storeBundleId  String?
  rating         Int
  comment        String?
  operatorReply  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  service StoreService? @relation(fields: [storeServiceId], references: [id])
  bundle  StoreBundle?  @relation(fields: [storeBundleId], references: [id])
}

model SupportTicket {
  id           String              @id @default(cuid())
  ticketNumber String              @unique
  userId       String
  orderId      String?
  subject      String
  description  String
  status       SupportTicketStatus @default(OPEN)
  type         SupportTicketType   @default(GENERAL)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  order     Order?     @relation(fields: [orderId], references: [id])
  chatRooms ChatRoom[]
}

model ChatRoom {
  id        String   @id @default(cuid())
  name      String?
  orderId   String?
  ticketId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order        Order?            @relation(fields: [orderId], references: [id])
  ticket       SupportTicket?    @relation(fields: [ticketId], references: [id])
  participants ChatParticipant[]
  messages     ChatMessage[]
}

model ChatParticipant {
  id         String    @id @default(cuid())
  roomId     String
  userId     String?
  operatorId String?
  joinedAt   DateTime  @default(now())
  lastRead   DateTime?

  room     ChatRoom  @relation(fields: [roomId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  operator Operator? @relation(fields: [operatorId], references: [id])
}

model ChatMessage {
  id               String   @id @default(cuid())
  roomId           String
  senderUserId     String?
  senderOperatorId String?
  content          String
  isDeleted        Boolean  @default(false)
  isEdited         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  room           ChatRoom  @relation(fields: [roomId], references: [id])
  senderUser     User?     @relation("UserMessages", fields: [senderUserId], references: [id])
  senderOperator Operator? @relation("OperatorMessages", fields: [senderOperatorId], references: [id])
}

model LiveSupportRoom {
  id        String   @id @default(cuid())
  userId    String   @unique
  channelId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages LiveSupportMessage[]
}

model LiveSupportMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String // userId or adminId
  content   String
  createdAt DateTime @default(now())

  room LiveSupportRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model EmailSupport {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model SupportPhone {
  id        String   @id @default(cuid())
  number    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppPage {
  id        String   @id @default(cuid())
  type      PageType @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
