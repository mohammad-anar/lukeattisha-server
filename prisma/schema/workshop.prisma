model Workshop {
    id           String  @id @default(uuid())
    email        String  @unique
    password     String
    phone        String? @unique
    role         Role    @default(WORKSHOP)
    avatar       String?
    workshopName String
    ownerName    String
    cvrNumber    String
    description  String?
    address      String?
    country      String?
    state        String?
    city         String
    postalCode   String
    latitude     Float?
    longitude    Float?
    isVerified   Boolean @default(false)

    approvalStatus WorkshopApprovalStatus @default(PENDING)
    avgRating      Float                  @default(0)
    reviewsCount   Int                    @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    categories           WorkshopCategory[]
    bookings             Booking[]
    jobs                 JobOffer[]
    invoices             Invoice[]
    rooms                Room[]
    workshopOpeningHours WorkshopOpeningHour[]

    @@index([approvalStatus])
}

model WorkshopOpeningHour {
    id String @id @default(uuid())

    workshopId String
    workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

    day       WeekDay
    openTime  String?
    closeTime String?
    isClosed  Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([workshopId, day])
}

model WorkshopCategory {
    id         String   @id @default(uuid())
    workshopId String
    categoryId String
    workshop   Workshop @relation(fields: [workshopId], references: [id])
    category   Category @relation(fields: [categoryId], references: [id])

    @@unique([workshopId, categoryId])
}
