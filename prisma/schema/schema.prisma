// prisma/schema/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  USER
  OPERATOR
  ADMIN
  SUPER_ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PICKED_UP
  PROCESSING
  READY_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  ESCROW_HELD
  DISBURSED
  REFUNDED
}

enum PayoutStatus {
  NOT_APPLICABLE
  HELD_IN_ESCROW
  DISBURSED
  RETAINED
}

enum AdStatus {
  PENDING
  ACTIVE
  EXPIRED
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TransactionType {
  ORDER_REVENUE
  SUBSCRIPTION_FEE
  WITHDRAWAL
  PLATFORM_COMMISSION
  REFUND
}

enum BannerType {
  FULL
  HALF
  SMALL
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationType {
  ORDER_UPDATE
  PROMOTION
  SYSTEM
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketType {
  ORDER_ISSUE
  PAYMENT_ISSUE
  GENERAL
}

// ─────────────────────────────────────────────────────────────
// CORE IDENTITY (USER & AUTH)
// ─────────────────────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  userId             String?  @unique
  name               String
  email              String   @unique
  phone              String?
  avatar             String?
  password           String
  role               UserRole @default(USER)
  isVerified         Boolean  @default(false)
  isDeleted          Boolean  @default(false)
  lat                Float?
  lng                Float?
  stripeCustomerId   String?
  isSubscribed       Boolean  @default(false)
  isTwoFactorEnabled Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Creator Tracking (Super Admin creates Admins/Operators)
  createdById  String?
  createdBy    User?   @relation("AdminCreator", fields: [createdById], references: [id])
  createdUsers User[]  @relation("AdminCreator")

  // Profile Extensions
  operatorProfile Operator?
  adminWallet     AdminWallet?

  // Relations
  addresses         Address[]
  cart              Cart[]
  orders            Order[]
  reviews           Review[]
  favouriteServices FavouriteService[]
  userSubscriptions UserSubscription[]
  notifications     Notification[]
  supportTickets    SupportTicket[]
  chatParticipants  ChatParticipant[]
  chatMessages      ChatMessage[]      @relation("UserMessages")
  paymentCards      UserPaymentCard[]  @relation("UserCards")

  @@index([createdById])
}

model Operator {
  id         String  @id @default(cuid())
  operatorId String? @unique

  // Link to Auth User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Business Logistics
  approvalStatus           ApprovalStatus @default(PENDING)
  stripeConnectedAccountId String?        @unique
  onboardingUrl            String?
  onboardingComplete       Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores           Store[]
  services         Service[]
  addons           Addon[]
  bundles          Bundle[]
  adSubscriptions  AdSubscription[]
  ads              Ad[]
  operatorWallet   OperatorWallet?
  chatParticipants ChatParticipant[]
  chatMessages     ChatMessage[]     @relation("OperatorMessages")
  notifications    Notification[]
  withdrawals      Withdrawal[]
}

// ─────────────────────────────────────────────────────────────
// LOGISTICS & SERVICES
// ─────────────────────────────────────────────────────────────

model Address {
  id            String   @id @default(cuid())
  userId        String
  streetAddress String
  city          String
  state         String?
  country       String
  postalCode    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services           Service[]
  operatorCategories OperatorCategory[]
}

model OperatorCategory {
  id         String   @id @default(cuid())
  operatorId String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
}

model Service {
  id          String   @id @default(cuid())
  serviceId   String?  @unique
  operatorId  String
  categoryId  String
  name        String
  basePrice   Decimal  @db.Decimal(10, 2)
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  operator       Operator           @relation(fields: [operatorId], references: [id])
  category       Category           @relation(fields: [categoryId], references: [id])
  serviceAddons  ServiceAddon[]
  storeServices  StoreService[]
  bundleServices BundleServices[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  reviews        Review[]
  favourites     FavouriteService[]
  ads            Ad[]
}

model ServiceAddon {
  id        String   @id @default(cuid())
  serviceId String
  addonId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id])
  addon   Addon   @relation(fields: [addonId], references: [id])
}

model Addon {
  id          String   @id @default(cuid())
  operatorId  String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  operator       Operator        @relation(fields: [operatorId], references: [id])
  serviceAddons  ServiceAddon[]
  selectedAddons SelectedAddon[]
  orderAddons    OrderAddon[]
}

model FavouriteService {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// STORE & BUNDLE
// ─────────────────────────────────────────────────────────────

model Store {
  id         String   @id @default(cuid())
  operatorId String
  name       String
  logo       String?
  banner     String?
  address    String?
  country    String?
  state      String?
  city       String?
  postalCode String?
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  operator       Operator         @relation(fields: [operatorId], references: [id])
  storeServices  StoreService[]
  storeBundles   StoreBundle[]
  bundleServices BundleServices[]
  carts          Cart[]
  orders         Order[]
}

model StoreService {
  id        String   @id @default(cuid())
  storeId   String
  serviceId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
}

model Bundle {
  id          String   @id @default(cuid())
  operatorId  String
  name        String
  description String?
  image       String?
  bundlePrice Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  operator       Operator         @relation(fields: [operatorId], references: [id])
  bundleServices BundleServices[]
  storeBundles   StoreBundle[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  ads            Ad[]
}

model BundleServices {
  bundleId  String
  serviceId String
  storeId   String?

  bundle  Bundle  @relation(fields: [bundleId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  store   Store?  @relation(fields: [storeId], references: [id])

  @@id([bundleId, serviceId])
}

model StoreBundle {
  storeId  String
  bundleId String

  store  Store  @relation(fields: [storeId], references: [id])
  bundle Bundle @relation(fields: [bundleId], references: [id])

  @@id([storeId, bundleId])
}

// ─────────────────────────────────────────────────────────────
// CART & ORDER
// ─────────────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  store Store      @relation(fields: [storeId], references: [id])
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  serviceId String?
  bundleId  String?
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart           Cart            @relation(fields: [cartId], references: [id])
  service        Service?        @relation(fields: [serviceId], references: [id])
  bundle         Bundle?         @relation(fields: [bundleId], references: [id])
  selectedAddons SelectedAddon[]

  @@unique([cartId, serviceId])
  @@unique([cartId, bundleId])
}

model SelectedAddon {
  cartItemId String
  addonId    String

  cartItem CartItem @relation(fields: [cartItemId], references: [id])
  addon    Addon    @relation(fields: [addonId], references: [id])

  @@id([cartItemId, addonId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  storeId         String
  totalAmount     Decimal       @db.Decimal(10, 2)
  platformFee     Decimal       @db.Decimal(10, 2)
  operatorAmount  Decimal       @db.Decimal(10, 2)
  stripeSessionId String?
  paymentStatus   PaymentStatus @default(UNPAID)
  status          OrderStatus   @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user             User                        @relation(fields: [userId], references: [id])
  store            Store                       @relation(fields: [storeId], references: [id])
  orderItems       OrderItem[]
  payments         Payment[]
  supportTickets   SupportTicket[]
  chatRooms        ChatRoom[]
  operatorWalletTx OperatorWalletTransaction[]
  adminWalletTx    AdminWalletTransaction[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  serviceName String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  serviceId   String?
  bundleId    String?
  createdAt   DateTime @default(now())

  order       Order        @relation(fields: [orderId], references: [id])
  service     Service?     @relation(fields: [serviceId], references: [id])
  bundle      Bundle?      @relation(fields: [bundleId], references: [id])
  orderAddons OrderAddon[]
}

model OrderAddon {
  orderItemId String
  addonId     String

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  addon     Addon     @relation(fields: [addonId], references: [id])

  @@id([orderItemId, addonId])
}

// ─────────────────────────────────────────────────────────────
// PAYMENT & WALLET
// ─────────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  orderId               String
  stripeSessionId       String?
  stripePaymentIntentId String?
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  platformFee           Decimal       @db.Decimal(10, 2)
  operatorAmount        Decimal       @db.Decimal(10, 2)
  paymentMethod         String?
  status                PaymentStatus @default(UNPAID)
  payoutStatus          PayoutStatus  @default(NOT_APPLICABLE)
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model UserPaymentCard {
  id             String   @id @default(cuid())
  userId         String
  stripeMethodId String
  last4          String
  brand          String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], name: "UserCards")
}

model OperatorWallet {
  id         String  @id @default(cuid())
  operatorId String  @unique
  balance    Decimal @default(0) @db.Decimal(12, 2)

  operator     Operator                    @relation(fields: [operatorId], references: [id])
  transactions OperatorWalletTransaction[]
}

model Withdrawal {
  id               String       @id @default(cuid())
  operatorId       String
  amount           Decimal      @db.Decimal(10, 2)
  status           PayoutStatus @default(HELD_IN_ESCROW)
  stripeTransferId String?
  createdAt        DateTime     @default(now())

  operator     Operator                    @relation(fields: [operatorId], references: [id])
  transactions OperatorWalletTransaction[]
}

model OperatorWalletTransaction {
  id              String          @id @default(cuid())
  walletId        String
  amount          Decimal         @db.Decimal(10, 2)
  transactionType TransactionType
  orderId         String?
  withdrawalId    String?
  note            String?
  createdAt       DateTime        @default(now())

  wallet     OperatorWallet @relation(fields: [walletId], references: [id])
  order      Order?         @relation(fields: [orderId], references: [id])
  withdrawal Withdrawal?    @relation(fields: [withdrawalId], references: [id])
}

model AdminWallet {
  id      String  @id @default(cuid())
  userId  String  @unique
  balance Decimal @default(0) @db.Decimal(12, 2)

  user         User                     @relation(fields: [userId], references: [id])
  transactions AdminWalletTransaction[]
}

model AdminWalletTransaction {
  id              String          @id @default(cuid())
  walletId        String
  amount          Decimal         @db.Decimal(10, 2)
  transactionType TransactionType
  orderId         String?
  note            String?
  createdAt       DateTime        @default(now())

  wallet AdminWallet @relation(fields: [walletId], references: [id])
  order  Order?      @relation(fields: [orderId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// SUPPORT & CHAT
// ─────────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(cuid())
  reviewNumber  String?  @unique
  userId        String
  serviceId     String
  rating        Int
  comment       String?
  operatorReply String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
}

model SupportTicket {
  id           String              @id @default(cuid())
  ticketNumber String              @unique
  userId       String
  orderId      String?
  subject      String
  description  String
  status       SupportTicketStatus @default(OPEN)
  type         SupportTicketType   @default(GENERAL)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  order     Order?     @relation(fields: [orderId], references: [id])
  chatRooms ChatRoom[]
}

model ChatRoom {
  id        String   @id @default(cuid())
  name      String?
  orderId   String?
  ticketId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order        Order?            @relation(fields: [orderId], references: [id])
  ticket       SupportTicket?    @relation(fields: [ticketId], references: [id])
  participants ChatParticipant[]
  messages     ChatMessage[]
}

model ChatParticipant {
  id         String    @id @default(cuid())
  roomId     String
  userId     String?
  operatorId String?
  joinedAt   DateTime  @default(now())
  lastRead   DateTime?

  room     ChatRoom  @relation(fields: [roomId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  operator Operator? @relation(fields: [operatorId], references: [id])
}

model ChatMessage {
  id               String   @id @default(cuid())
  roomId           String
  senderUserId     String?
  senderOperatorId String?
  content          String
  isDeleted        Boolean  @default(false)
  isEdited         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  room           ChatRoom  @relation(fields: [roomId], references: [id])
  senderUser     User?     @relation("UserMessages", fields: [senderUserId], references: [id])
  senderOperator Operator? @relation("OperatorMessages", fields: [senderOperatorId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// ADMIN & ADS
// ─────────────────────────────────────────────────────────────

model AdminSetting {
  id                     String   @id @default(cuid())
  platformCommissionRate Decimal  @default(0.1) @db.Decimal(5, 2)
  payoutSchedule         String?  @default("weekly")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Banner {
  id         String     @id @default(cuid())
  title      String
  image      String?
  bannerType BannerType @default(FULL)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Notification {
  id         String              @id @default(cuid())
  userId     String?
  operatorId String?
  title      String
  message    String
  channel    NotificationChannel @default(IN_APP)
  type       NotificationType    @default(SYSTEM)
  isSent     Boolean             @default(false)
  createdAt  DateTime            @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  operator Operator? @relation(fields: [operatorId], references: [id])
}

model AdSubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  durationMonth Int
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions AdSubscription[]
}

model AdSubscription {
  id              String             @id @default(cuid())
  operatorId      String
  planId          String
  startDate       DateTime
  endDate         DateTime
  status          SubscriptionStatus @default(PENDING)
  stripePaymentId String?

  operator Operator           @relation(fields: [operatorId], references: [id])
  plan     AdSubscriptionPlan @relation(fields: [planId], references: [id])
  ads      Ad[]
}

model Ad {
  id             String   @id @default(cuid())
  operatorId     String
  subscriptionId String
  serviceId      String?
  bundleId       String?
  status         AdStatus @default(PENDING)
  createdAt      DateTime @default(now())

  operator     Operator       @relation(fields: [operatorId], references: [id])
  subscription AdSubscription @relation(fields: [subscriptionId], references: [id])
  service      Service?       @relation(fields: [serviceId], references: [id])
  bundle       Bundle?        @relation(fields: [bundleId], references: [id])
}

model UserSubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  durationMonth Int
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions UserSubscription[]
}

model UserSubscription {
  id              String             @id @default(cuid())
  userId          String
  planId          String
  startDate       DateTime
  endDate         DateTime
  status          SubscriptionStatus @default(PENDING)
  stripePaymentId String?

  user User                 @relation(fields: [userId], references: [id])
  plan UserSubscriptionPlan @relation(fields: [planId], references: [id])
}
