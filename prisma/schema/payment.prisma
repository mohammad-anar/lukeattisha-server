model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @unique
  stripePaymentIntentId String        @unique
  stripeTransferGroup   String
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  status                PaymentStatus @default(UNPAID)
  paymentUrl            String?
  paidAt                DateTime?
  transactionId         String?       @unique
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order     Order      @relation(fields: [orderId], references: [id])
  transfers Transfer[]
}

model Transfer {
  id                   String         @id @default(cuid())
  paymentId            String
  operatorId           String
  stripeConnectedAccId String
  amount               Decimal        @db.Decimal(10, 2)
  stripeTransferId     String?
  status               TransferStatus @default(PENDING)
  createdAt            DateTime       @default(now())

  payment  Payment  @relation(fields: [paymentId], references: [id])
  operator Operator @relation(fields: [operatorId], references: [id])
}

model UserPaymentCard {
  id             String   @id @default(cuid())
  userId         String
  stripeMethodId String
  last4          String
  brand          String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], name: "UserCards")
}

model OperatorWallet {
  id         String  @id @default(cuid())
  operatorId String  @unique
  balance    Decimal @default(0) @db.Decimal(12, 2)

  operator     Operator                    @relation(fields: [operatorId], references: [id])
  transactions OperatorWalletTransaction[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
}

model Withdrawal {
  id               String       @id @default(cuid())
  operatorId       String
  amount           Decimal      @db.Decimal(10, 2)
  status           PayoutStatus @default(HELD_IN_ESCROW)
  stripeTransferId String?
  createdAt        DateTime     @default(now())

  operator     Operator                    @relation(fields: [operatorId], references: [id])
  transactions OperatorWalletTransaction[]
}

model OperatorWalletTransaction {
  id        String          @id @default(cuid())
  walletId  String
  amount    Decimal         @db.Decimal(10, 2)
  type      TransactionType
  operatorId String?
  orderId   String?
  withdrawalId String?
  refundId     String?
  note      String?
  createdAt DateTime        @default(now())

  wallet     OperatorWallet @relation(fields: [walletId], references: [id])
  order      Order?         @relation(fields: [orderId], references: [id])
  withdrawal Withdrawal?    @relation(fields: [withdrawalId], references: [id])
  operator   Operator?      @relation(fields: [operatorId], references: [id])
  refund     Refund?        @relation(fields: [refundId], references: [id])
}

model AdminWallet {
  id      String  @id @default(cuid())
  userId  String  @unique
  balance Decimal @default(0) @db.Decimal(12, 2)

  user         User                     @relation(fields: [userId], references: [id])
  transactions AdminWalletTransaction[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
}

model AdminWalletTransaction {
  id        String          @id @default(cuid())
  walletId  String
  amount    Decimal         @db.Decimal(10, 2)
  type      TransactionType
  orderId   String?
  refundId  String?
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  wallet AdminWallet @relation(fields: [walletId], references: [id])
  order  Order?      @relation(fields: [orderId], references: [id])
  refund Refund?     @relation(fields: [refundId], references: [id])
}
