model AdminSetting {
  id                      String   @id @default(cuid())
  platformCommissionRate  Decimal  @default(0.1) @db.Decimal(5, 2)
  calcellationWindowHours Int      @default(24)
  bookingLeadTimeHours    Int      @default(24)
  requirePaymentUpFront   Boolean  @default(false)
  allowPartialPayment     Boolean  @default(false)
  fixedTransactionFee     Decimal  @default(0) @db.Decimal(10, 2)
  paymentProcessingFee    Decimal  @default(0) @db.Decimal(5, 2)
  pickupAndDeliveryFee    Decimal  @default(4.99) @db.Decimal(10, 2)
  payoutSchedule          String?  @default("weekly")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model LegalDocument {
  id        String   @id @default(cuid())
  type      String   @unique // e.g., 'PRIVACY_POLICY', 'TERMS_AND_CONDITIONS'
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id              String     @id @default(cuid())
  title           String
  description     String?
  image           String?
  buttonText      String?
  backgroundColor String?    @default("#FFFFFF")
  textColor       String?    @default("#000000")
  bannerType      BannerType @default(PROMOTION)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Notification {
  id         String              @id @default(cuid())
  userId     String?
  operatorId String?
  title      String
  message    String
  channel    NotificationChannel @default(IN_APP)
  type       NotificationType    @default(SYSTEM)
  isSent     Boolean             @default(false)
  isRead     Boolean             @default(false)
  createdAt  DateTime            @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  operator Operator? @relation(fields: [operatorId], references: [id])
}

model AdSubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  durationMonth Int
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions AdSubscription[]
}

model AdSubscription {
  id              String             @id @default(cuid())
  operatorId      String
  planId          String
  startDate       DateTime
  endDate         DateTime
  status          SubscriptionStatus @default(PENDING)
  stripePaymentId String?
  transactionId   String?            @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  operator Operator           @relation(fields: [operatorId], references: [id])
  plan     AdSubscriptionPlan @relation(fields: [planId], references: [id])
  ads      Ad[]
  invoice  Invoice?
}

model Ad {
  id             String   @id @default(cuid())
  operatorId     String
  subscriptionId String
  storeServiceId String?
  storeBundleId  String?
  status         AdStatus @default(PENDING)
  createdAt      DateTime @default(now())

  operator     Operator       @relation(fields: [operatorId], references: [id])
  subscription AdSubscription @relation(fields: [subscriptionId], references: [id])
  storeService StoreService?  @relation(fields: [storeServiceId], references: [id])
  storeBundle  StoreBundle?   @relation(fields: [storeBundleId], references: [id])
  orders       Order[]
}

model UserSubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  durationMonth Int
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions UserSubscription[]
}

model UserSubscription {
  id              String             @id @default(cuid())
  userId          String
  planId          String
  startDate       DateTime
  endDate         DateTime
  status          SubscriptionStatus @default(PENDING)
  stripePaymentId String?
  transactionId   String?            @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user    User                 @relation(fields: [userId], references: [id])
  plan    UserSubscriptionPlan @relation(fields: [planId], references: [id])
  invoice Invoice?
}
