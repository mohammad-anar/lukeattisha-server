model Notification {
  id     String @id @default(uuid())
  userId String

  title   String
  message String
  type    String
  channel String

  isSent    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationPreference {
  id     String @id @default(uuid())
  userId String @unique

  orderUpdatesEmail Boolean @default(true)
  orderUpdatesSMS   Boolean @default(false)
  orderUpdatesPush  Boolean @default(true)

  marketingEmail Boolean @default(false)
  marketingSMS   Boolean @default(false)
  marketingPush  Boolean @default(false)

  chatPush Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
