model Notification {
  id            String    @id @default(uuid())
  title         String
  body          String
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userIds       String[]  // recipients
  workshopIds   String[]  // recipients

  triggeredById String?   // actor (user, workshop, admin)
  jobId         String?
  bookingId     String?
  invoiceId     String?   // optional if invoice
  eventType     String     // "JOB_CREATED", "OFFER_SENT", "OFFER_ACCEPTED", etc.
}


model ChatNotification {
  id            String   @id @default(uuid())
  userIds       String[] // recipients
  chatRoomId    String
  messageId     String
  triggeredById String?  // sender
  title         String?
  body          String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}