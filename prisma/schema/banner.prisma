model Banner {
  id              String      @id @default(uuid())
  title           String
  description     String?
  buttonText      String?
  bannerType      BannerType?
  backgroundColor String?
  textColor       String?
  isActive        Boolean     @default(true)
  image           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BannerType {
  PROMOTION
  MEMBERSHIP
  SEASONAL
  OFFER
}
