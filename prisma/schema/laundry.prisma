model AdminSetting {
  id String @id @default("1")

  cancellationWindowHours Int     @default(24)
  bookingLeadTimeHours    Int     @default(2)
  requirePaymentUpfront   Boolean @default(true)
  allowPartialPayments    Boolean @default(false)

  platformCommissionRate Decimal @default(10.0) @db.Decimal(5, 2)
  fixedTransactionFee    Decimal @default(0.50) @db.Decimal(10, 2)
  pickupDeliveryFee      Decimal @default(4.99) @db.Decimal(10, 2)

  payoutSchedule String @default("WEEKLY")

  updatedAt DateTime @updatedAt
}
