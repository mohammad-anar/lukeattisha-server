{
  "info": {
    "name": "Lukeattisha API - Form-Data",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "auth",
      "item": [
        { "name": "Register User", "request": { "method": "POST", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "John User", "type": "text" }, { "key": "email", "value": "john@example.com", "type": "text" }, { "key": "password", "value": "password123", "type": "text" }, { "key": "phone", "value": "12345678", "type": "text" }, { "key": "image", "type": "file", "src": [] } ] }, "url": "{{baseUrl}}/auth/register" } },
        { "name": "Register Operator", "request": { "method": "POST", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "Op Owner", "type": "text" }, { "key": "email", "value": "op@example.com", "type": "text" }, { "key": "password", "value": "password123", "type": "text" }, { "key": "storeName", "value": "Op Laundry", "type": "text" }, { "key": "address", "value": "123 Op St", "type": "text" }, { "key": "image", "type": "file", "src": [] } ] }, "url": "{{baseUrl}}/auth/register/operator" } },
        { "name": "Login", "event": [ { "listen": "test", "script": { "exec": [ "var jsonData = JSON.parse(responseBody);", "if(jsonData.data && jsonData.data.accessToken) {", "    var role = jsonData.data.user.role.toLowerCase();", "    pm.collectionVariables.set(role + \"AccessToken\", jsonData.data.accessToken);", "}" ] } } ], "request": { "method": "POST", "body": { "mode": "json", "json": { "email": "john@example.com", "password": "password123" } }, "url": "{{baseUrl}}/auth/login" } }
      ]
    },
    {
      "name": "user",
      "item": [
        { "name": "Get Me (Profile)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userAccessToken}}", "type": "string" }] }, "method": "GET", "url": "{{baseUrl}}/user/get-me" } },
        { "name": "Get Me (Operator)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorAccessToken}}", "type": "string" }] }, "method": "GET", "url": "{{baseUrl}}/user/get-me" } },
        { "name": "Get Me (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminAccessToken}}", "type": "string" }] }, "method": "GET", "url": "{{baseUrl}}/user/get-me" } },
        { "name": "Create Admin (Super Only)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{super_adminAccessToken}}", "type": "string" }] }, "method": "POST", "body": { "mode": "json", "json": { "name": "Admin", "email": "admin@example.com", "password": "password123" } }, "url": "{{baseUrl}}/user/create-admin" } }
      ]
    },
    {
      "name": "service",
      "item": [
        { "name": "Create Service (Form-Data)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorAccessToken}}", "type": "string" }] }, "method": "POST", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "Dry Clean", "type": "text" }, { "key": "categoryId", "value": "CAT_ID", "type": "text" }, { "key": "basePrice", "value": "20", "type": "text" }, { "key": "description", "value": "High quality clean", "type": "text" }, { "key": "image", "type": "file", "src": [] } ] }, "url": "{{baseUrl}}/service" } },
        { "name": "Get Services by Distance", "request": { "method": "GET", "url": "{{baseUrl}}/service?userLat=57.7&userLng=11.9" } }
      ]
    },
    {
      "name": "ad",
      "item": [
        { "name": "Get Ads (Sorted)", "request": { "method": "GET", "url": "{{baseUrl}}/ad?userLat=57.7&userLng=11.9" } }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "adminAccessToken", "value": "", "type": "string" },
    { "key": "userAccessToken", "value": "", "type": "string" },
    { "key": "operatorAccessToken", "value": "", "type": "string" },
    { "key": "super_adminAccessToken", "value": "", "type": "string" }
  ]
}
